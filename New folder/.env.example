PORT=8489

# MySQL
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=
DB_NAME=whatsapp_api

# JWT
JWT_SECRET=change-me

# Ubuntu — your server path (verified: /usr/bin/google-chrome)
CHROME_PATH=/usr/bin/google-chrome

# WhatsApp session files (use absolute path on production)
SESSION_PATH=/var/lib/whatsapp-api/.wwebjs_auth

# Chrome writable HOME (fixes /root/.local/share permission errors on Ubuntu)
CHROME_HOME=/var/lib/whatsapp-api/chrome-home

# Optional: extra Chrome flags (comma-separated)
# CHROME_EXTRA_ARGS=--window-size=1280,720

# Puppeteer timeouts (ms)
PUPPETEER_TIMEOUT_MS=120000
PUPPETEER_PROTOCOL_TIMEOUT_MS=120000

# Admin users (Super Admin page) — comma-separated IDs or usernames
ADMIN_USER_IDS=1
ADMIN_USERNAMES=admin
